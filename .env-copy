# ==========================================
# Fichier de configuration d'environnement
# Copiez ce fichier en ".env" et remplissez vos clés
# ==========================================

# 1. Clés d'API (au moins l'une des deux selon le backend choisi)
MISTRAL_API_KEY=""
NIM_API_KEY=""

# 2. Choix du mode d'exécution
# Valeurs possibles : "api" (Mistral), "nim" (Nvidia), "lmstudio" (Local), "ollama" (Ollama Local), ou "auto"
AGORA_CLAIMS_BACKEND="lmstudio"

# 3. Choix des modèles (Optionnel - Valeurs par défaut indiquées)
# Décommentez (enlevez le #) et modifiez si vous souhaitez utiliser un autre modèle :
# AGORA_NIM_MODEL="mistralai/mistral-small-4-119b-2603"
AGORA_LMSTUDIO_MODEL="mistral-7b-instruct-v0.3"
# AGORA_CLAIMS_API_MODEL="ministral-3b-latest"

# 4. Paramètres de Serveur Optionnels
# AGORA_API_TOKEN=""   # Optionnel : Mettez un mot de passe pour sécuriser l'accès à l'API
# AGORA_PUBLIC="0"     # Optionnel : Mettez à "1" pour rendre l'interface publique
